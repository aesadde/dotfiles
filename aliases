# Common aliases
if command -v lsd &>/dev/null; then
  alias ls='lsd'
  alias lk='lsd -laSr'
  alias lt='lsd -latr'
  alias la='lsd -lha'
  alias lg='lsd -la | grep'
fi
alias lcount='ls -1 | wc -l'
alias grep='grep --color=auto'
alias rm='rm -iv'
alias cp='cp -v'
alias mv='mv -v'
alias mkdir='mkdir -pv'

# Modern tool replacements (if installed)
command -v bat &>/dev/null && alias cat='bat'
command -v htop &>/dev/null && alias top='htop'
command -v dust &>/dev/null && alias du='dust'
command -v duf &>/dev/null && alias df='duf'

# Editors
alias ev='nvim ~/dotfiles/nvim/init.lua'

# Git (git-specific aliases are in gitconfig)
alias g\?='git status'
alias save='git add . && git commit -m "chore: save progress"'

# Tmux
alias tn='tmux new-session -s'
alias tml='tmux ls'
alias tma='tmux attach -t'

# macOS
alias hiddentrue='defaults write com.apple.finder AppleShowAllFiles TRUE & killall Finder'
alias hiddenfalse='defaults write com.apple.finder AppleShowAllFiles FALSE & killall Finder'
alias afk="/System/Library/CoreServices/Menu\ Extras/User.menu/Contents/Resources/CGSession -suspend"

# Make watch work with aliases
alias watch='watch '

# ZSH suffix aliases
alias -s {md,yml,yaml,txt,rst}=nvim

# Shortcuts
alias s=ssh
alias c=clear
alias cx='chmod +x'
alias more=less
alias cc=claude

alias brew='arch -arm64 brew'
